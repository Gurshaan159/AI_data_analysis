# Lava gateway (see https://lava.so/docs — forward requests use POST /v1/forward)
VITE_LAVA_API_BASE_URL=https://api.lava.so/v1
VITE_LAVA_API_KEY=
# OpenAI-compatible upstream chat endpoint (forwarded by Lava)
VITE_LAVA_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
VITE_LAVA_MODEL=gpt-4o-mini
VITE_AI_PROVIDER=mock
