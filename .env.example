# OpenAI (AI-assisted planning). Requests go directly to the OpenAI Chat Completions API (Bearer key below).
# Vite/Tauri dev loads this automatically; tsx tests use tests/loadDotenv.ts.
#
# Paste key on ONE of these lines (preferred first). Legacy LAVA_* names still work — they are aliases, not a separate gateway.
# VITE_AI_PROVIDER=mock   # optional: force offline mock planner
VITE_OPENAI_API_KEY=
# VITE_LAVA_API_KEY=
# Optional overrides (defaults shown):
# VITE_OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# VITE_OPENAI_MODEL=gpt-4o-mini
